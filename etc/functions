#!/usr/bin/env bash

echo "Helper functions from vvg-box repository is being sourced..."

# add helper function
repeat() { while :; do "$@" && return; sleep 5; done }

# taken from https://gist.github.com/sj26/88e1c6584397bb7c13bd11108a579746
retry() {
  local retries="$1"
  shift

  local count=0
  until "$@"; do
    exit=$?
    wait=$((2 ** count))
    count=$((count + 1))
    if [ "$count" -lt "$retries" ]; then
      echo "Retry $count/$retries exited $exit, retrying in $wait seconds..."
      sleep "$wait"
    else
      echo "Retry $count/$retries exited $exit, no more retries left."
      return $exit
    fi
  done
  return 0
}


# usage: defined_and_contains_any EXCLUDE snakemake c++ c
defined_and_contains_any() {
    # Check if the variable name is actually set
    [[ -v "$1" ]] || return 1

    local _target_name="$1"
    shift
    
    # Use indirect expansion (!) to get the value of the variable name
    # This is more compatible and avoids nameref self-reference errors
    local _value="${!_target_name}"

    # Loop through remaining arguments (substrings)
    local _sub
    for _sub in "$@"; do
        if [[ "$_value" == *"$_sub"* ]]; then
            return 0
        fi
    done

    return 1
}

pixi-global-install() {
  local file="$1"

  if [[ ! -f "$file" ]]; then
    echo "Error: File '$file' not found."
    return 1
  fi

  while IFS= read -r line || [[ -n "$line" ]]; do
    # Trim whitespace
    line=$(echo "$line" | xargs)

    # Skip empty lines and comments
    [[ -z "$line" || "$line" == \#* ]] && continue

    expanded_line=$(eval echo "$line")
    echo "Expanded line: $expanded_line"

    echo "Executing: pixi global install $expanded_line"
    # run pixi global install for each line
    retry 5 pixi global install $expanded_line
  done < "$file"
}

