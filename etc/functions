#!/usr/bin/env bash

echo ">>>> Helper functions from vvg-box repository is being sourced..."
echo ">>>> loaded: repeat retry defined_and_contains_any save_env_vars render_env pixi-global-install pixi-add"

# add helper function
repeat() { while :; do "$@" && return; sleep 5; done }

# taken from https://gist.github.com/sj26/88e1c6584397bb7c13bd11108a579746
retry() {
  local retries="$1"
  shift

  local count=0
  until "$@"; do
    exit=$?
    wait=$((2 ** count))
    count=$((count + 1))
    if [ "$count" -lt "$retries" ]; then
      echo "Retry $count/$retries exited $exit, retrying in $wait seconds..."
      sleep "$wait"
    else
      echo "Retry $count/$retries exited $exit, no more retries left."
      return $exit
    fi
  done
  return 0
}


# usage: defined_and_contains_any EXCLUDE snakemake c++ c
defined_and_contains_any() {
    # Check if the variable name is actually set
    [[ -v "$1" ]] || return 1

    local _target_name="$1"
    shift
    
    # Use indirect expansion (!) to get the value of the variable name
    # This is more compatible and avoids nameref self-reference errors
    local _value="${!_target_name}"

    # Loop through remaining arguments (substrings)
    local _sub
    for _sub in "$@"; do
        if [[ "$_value" == *"$_sub"* ]]; then
            return 0
        fi
    done

    return 1
}

save_env_vars() {
  # Default to a specific path if ETC_DIR isn't set globally
  local target_file="${ETC_DIR:-/etc}/inst-envvars"

  # Ensure the directory exists
  mkdir -p "$(dirname "$target_file")"

  for var in "$@"; do
    # 1. Check if the variable is actually set (optional but helpful)
    # 2. ${!var@Q} is a modern Bash (4.4+) feature that automatically
    #    quotes the value safely for re-use in shells.
    if [[ -v "$var" ]]; then
      echo "$var=${!var@Q}" >> "$target_file"
    else
      # If unset, save as empty or skip
      echo "$var=''" >> "$target_file"
    fi
  done
}

render_env() (
    set +u
    local input

    if (($#)); then
        input="$*"
    else
        input="$(cat)"
    fi

    eval "printf '%s\n' \"${input//\"/\\\"}\""
)

pixi-global-install() {
  local file="$1"

  if [[ ! -f "$file" ]]; then
    echo "Error: File '$file' not found."
    return 1
  fi

  while IFS= read -r line || [[ -n "$line" ]]; do
    # Trim whitespace
    line=$(echo "$line" | xargs)

    # Skip empty lines and comments
    [[ -z "$line" || "$line" == \#* ]] && continue

    expanded_line=$(echo "$line" | render_env)
    # if expanded_line is empty after rendering, skip it
    [[ -z "$expanded_line" || "$expanded_line" == \#* ]] && continue
    #echo "Expanded line: $expanded_line"
    read -ra cmd_args <<< "$expanded_line"

    echo "Executing: pixi global install ${cmd_args[*]}"
    # run pixi global install for each line
    retry 5 pixi global install "${cmd_args[@]}"
  done < "$file"
}

pixi-add() {
  local file="$1"

  if [[ ! -f "$file" ]]; then
    echo "Error: File '$file' not found."
    return 1
  fi

  while IFS= read -r line || [[ -n "$line" ]]; do
    # Trim whitespace
    line=$(echo "$line" | xargs)

    # Skip empty lines and comments
    [[ -z "$line" || "$line" == \#* ]] && continue

    expanded_line=$(echo "$line" | render_env)
    # if expanded_line is empty after rendering, skip it
    [[ -z "$expanded_line" || "$expanded_line" == \#* ]] && continue
    #echo "Expanded line: $expanded_line"
    read -ra cmd_args <<< "$expanded_line"

    echo "Executing: pixi add ${cmd_args[*]}"
    # run pixi add for each line
    retry 5 pixi add "${cmd_args[@]}"
  done < "$file"
}

