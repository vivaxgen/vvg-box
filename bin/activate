#!/usr/bin/env bash

# required exported environment
#   VVG_BASEDIR
#   PIXI_ENVNAME


# optional environment
#   BASHRC
#   SPAWN_SHELL
#   VVG_SILENT

#set -euo pipefail

BASHRC="${BASHRC:-"${VVG_BASEDIR}/etc/bashrc"}"

if [ "${SPAWN_SHELL:-0}" -ge 1 ]; then
    export SPAWN_SHELL=0

    echo "Spawning new non-login interactive shell..."
    # Use cat for better readability and easier quoting
    exec bash --init-file <(cat <<EOF
        [ -f ~/.bashrc ] && . ~/.bashrc
        [ -f "${BASHRC}" ] && . "${BASHRC}"
EOF
    )
else
    [[ "${VVG_SILENT:-0}" != "1" ]] && echo "Sourcing environment..."
    [ -f "${BASHRC}" ] && . "${BASHRC}"
fi

# EOF
